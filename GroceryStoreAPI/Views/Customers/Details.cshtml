@model GroceryStoreAPI.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Customer Details</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-warning">Edit Profile</a>
            <a asp-action="Index" class="btn btn-secondary">Back to Directory</a>
        </div>
    </div>
    <hr />

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h4 class="mb-0">@Model.FirstName @Model.LastName</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3 text-muted">Customer ID</dt>
                <dd class="col-sm-9">@Model.CustomerId</dd>

                <dt class="col-sm-3 text-muted">First Name</dt>
                <dd class="col-sm-9">@Model.FirstName</dd>

                <dt class="col-sm-3 text-muted">Last Name</dt>
                <dd class="col-sm-9">@Model.LastName</dd>

                <dt class="col-sm-3 text-muted">Email Address</dt>
                <dd class="col-sm-9">
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </dd>

                <dt class="col-sm-3 text-muted">Contact Number</dt>
                <dd class="col-sm-9">@Model.ContactNo</dd>
                <dt class="col-sm-3 text-muted">Residential Address</dt>
                <dd class="col-sm-9">@Model.Address</dd>
            </dl>
        </div>
        <div class="card-footer text-muted small">
            Grocery Store Management System - Customer ID: @Model.CustomerId
        </div>
    </div>
</div>